<?xml version="1.0" encoding="utf-8"?>
<!--
  themes.xml
  Localização: app/src/main/res/values/themes.xml
-->
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema principal: Material3 com cores WhatsApp -->
    <style name="Theme.WhatsAppArchiver" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/green_wa</item>
        <item name="colorPrimaryVariant">@color/teal_wa</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/green_light</item>
        <item name="colorSecondaryVariant">@color/teal_wa</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="android:statusBarColor">@color/green_wa</item>
        <item name="android:navigationBarColor">@color/bg_main</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Tema do Splash Screen -->
    <style name="Theme.WhatsAppArchiver.Splash" parent="Theme.WhatsAppArchiver">
        <item name="android:windowBackground">@color/green_wa</item>
    </style>

    <!-- Chip selector para o período dos gráficos -->
    <style name="Widget.App.Chip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/chip_selector</item>
        <item name="chipStrokeColor">@color/green_wa</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="android:textColor">@color/chip_text_selector</item>
    </style>

    <!-- Forma circular para avatares -->
    <style name="Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>
